    1  gcloud auth list
    2  export GOOGLE_CLOUD_PROJECT=$(gcloud config get-value core/project)
    3  gcloud iam service-accounts create my-natlang-sa   --display-name "my natural language service account"
    4  gcloud iam service-accounts keys create ~/key.json   --iam-account my-natlang-sa@${GOOGLE_CLOUD_PROJECT}.iam.gserviceaccount.com
    5  export GOOGLE_APPLICATION_CREDENTIALS="/home/USER/key.json"
    6  history
