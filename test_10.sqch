1  gcloud config set dataproc/region us-east4
    2  gcloud services disable dataproc.googleapis.com --force
    3  gcloud services enable dataproc.googleapis.com
    4  PROJECT_ID=$(gcloud config get-value project) && gcloud config set project $PROJECT_ID
    5  PROJECT_NUMBER=$(gcloud projects describe $PROJECT_ID --format='value(projectNumber)')
    6  gcloud projects add-iam-policy-binding $PROJECT_ID   --member=serviceAccount:$PROJECT_NUMBER-compute@developer.gserviceaccount.com   --role=roles/storage.admin
    7  gcloud projects add-iam-policy-binding $PROJECT_ID   --member=serviceAccount:$PROJECT_NUMBER-compute@developer.gserviceaccount.com   --role=roles/dataproc.worker
    8  gcloud compute networks subnets update default --region=us-east4  --enable-private-ip-google-access
    9  gcloud dataproc clusters create example-cluster --worker-boot-disk-size 500 --worker-machine-type=e2-standard-4 --master-machine-type=e2-standard-4
   10  hisotry
   11  gcloud dataproc jobs submit spark --cluster example-cluster   --class org.apache.spark.examples.SparkPi   --jars file:///usr/lib/spark/examples/jars/spark-examples.jar -- 1000
